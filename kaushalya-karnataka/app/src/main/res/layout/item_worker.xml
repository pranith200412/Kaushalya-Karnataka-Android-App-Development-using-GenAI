<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainer"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp"
    app:rippleColor="?attr/colorPrimary">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Avatar (initials fallback when no photo) -->
        <FrameLayout
            android:id="@+id/avatarContainer"
            android:layout_width="@dimen/avatar_md"
            android:layout_height="@dimen/avatar_md"
            android:background="@drawable/bg_avatar_circle"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/avatarInitialsTv"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="R"
                xmlns:tools="http://schemas.android.com/tools" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/avatarIv"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="@string/cd_avatar"
                app:shapeAppearance="@style/ShapeAppearance.Kaushalya.Avatar" />
        </FrameLayout>

        <!-- Name -->
        <TextView
            android:id="@+id/nameTv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="17sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toTopOf="@id/avatarContainer"
            app:layout_constraintStart_toEndOf="@id/avatarContainer"
            app:layout_constraintEnd_toStartOf="@id/ratingPill"
            tools:text="Ramesh Naik"
            xmlns:tools="http://schemas.android.com/tools" />

        <!-- Town / category line -->
        <TextView
            android:id="@+id/townTv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/nameTv"
            app:layout_constraintStart_toEndOf="@id/avatarContainer"
            app:layout_constraintEnd_toStartOf="@id/ratingPill"
            tools:text="Hubli · Electrician"
            xmlns:tools="http://schemas.android.com/tools" />

        <!-- Rating pill (top-right) -->
        <LinearLayout
            android:id="@+id/ratingPill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_rating_chip"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            app:layout_constraintTop_toTopOf="@id/avatarContainer"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_star"
                app:tint="@color/star_filled"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/ratingValueTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="?attr/colorOnTertiaryContainer"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="4.5"
                xmlns:tools="http://schemas.android.com/tools" />
        </LinearLayout>

        <!-- Bio -->
        <TextView
            android:id="@+id/bioTv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp"
            android:lineSpacingExtra="2dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/avatarContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="20 years of wiring homes and small shops. Same-day visits within Hubli–Dharwad."
            xmlns:tools="http://schemas.android.com/tools" />

        <!-- Bottom row: services count + starting price + chevron -->
        <TextView
            android:id="@+id/servicesCountTv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/bioTv"
            app:layout_constraintStart_toStartOf="parent"
            tools:text="3 services"
            xmlns:tools="http://schemas.android.com/tools" />

        <TextView
            android:id="@+id/startingAtTv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorPrimary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp"
            app:layout_constraintTop_toTopOf="@id/servicesCountTv"
            app:layout_constraintBottom_toBottomOf="@id/servicesCountTv"
            app:layout_constraintStart_toEndOf="@id/servicesCountTv"
            tools:text="Starting ₹200"
            xmlns:tools="http://schemas.android.com/tools" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_chevron_right"
            android:importantForAccessibility="no"
            app:layout_constraintTop_toTopOf="@id/servicesCountTv"
            app:layout_constraintBottom_toBottomOf="@id/servicesCountTv"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
