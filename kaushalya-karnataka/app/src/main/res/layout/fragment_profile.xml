<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="120dp">

            <!-- ============== HERO ============== -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:background="@drawable/bg_hero_gradient" />

                <ImageButton
                    android:id="@+id/backBtn"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="32dp"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_back"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/cd_back"
                    app:tint="#FFFFFF" />

                <ImageButton
                    android:id="@+id/editProfileBtn"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="32dp"
                    android:layout_marginEnd="12dp"
                    android:layout_gravity="end"
                    android:src="@drawable/ic_edit"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/edit_profile"
                    android:visibility="gone"
                    app:tint="#FFFFFF" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginTop="84dp"
                    android:paddingHorizontal="20dp">

                    <FrameLayout
                        android:id="@+id/avatarContainer"
                        android:layout_width="@dimen/avatar_lg"
                        android:layout_height="@dimen/avatar_lg"
                        android:background="@drawable/bg_avatar_circle">

                        <TextView
                            android:id="@+id/avatarInitialsTv"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:textColor="?attr/colorOnPrimaryContainer"
                            android:textSize="34sp"
                            android:textStyle="bold" />

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/avatarIv"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:visibility="gone"
                            android:contentDescription="@string/cd_avatar"
                            app:shapeAppearance="@style/ShapeAppearance.Kaushalya.Avatar" />
                    </FrameLayout>

                </LinearLayout>
            </FrameLayout>

            <TextView
                android:id="@+id/nameTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"
                android:textColor="?attr/colorOnSurface"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- Category + town pills -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/categoryPillTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_category_pill"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:textColor="?attr/colorOnSecondaryContainer"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/townPillTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_category_pill"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:textColor="?attr/colorOnSecondaryContainer"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Rating row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_rating_chip"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_star"
                    android:importantForAccessibility="no" />

                <TextView
                    android:id="@+id/ratingValueTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="?attr/colorOnTertiaryContainer"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="14dp"
                    android:layout_marginHorizontal="10dp"
                    android:background="?attr/colorOutlineVariant" />

                <TextView
                    android:id="@+id/reviewsCountTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorOnTertiaryContainer"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- ============== HIRE ME CTA ============== -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/hireMeBtn"
                style="@style/Widget.Kaushalya.Button.HireMe"
                android:layout_width="match_parent"
                android:layout_height="@dimen/hire_me_btn_height"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="22dp"
                android:text="@string/hire_me"
                app:icon="@drawable/ic_phone"
                app:iconGravity="textStart" />

            <!-- ============== ABOUT ============== -->
            <TextView
                android:id="@+id/aboutHeader"
                style="?attr/textAppearanceTitleLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_about"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="28dp" />

            <TextView
                android:id="@+id/bioTv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnSurface"
                android:textSize="15sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="6dp" />

            <!-- ============== PORTFOLIO ============== -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="28dp">

                <TextView
                    android:id="@+id/portfolioHeader"
                    style="?attr/textAppearanceTitleLarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_portfolio"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/addPortfolioBtn"
                    style="@style/Widget.Kaushalya.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/add_portfolio"
                    android:visibility="gone"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:icon="@drawable/ic_camera_alt" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/portfolioRv"
                android:layout_width="match_parent"
                android:layout_height="@dimen/portfolio_thumb"
                android:layout_marginTop="10dp"
                android:paddingHorizontal="20dp"
                android:clipToPadding="false"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/portfolioEmptyTv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/profile_no_portfolio"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:textStyle="italic"
                android:gravity="center"
                android:layout_marginHorizontal="20dp"
                android:padding="20dp"
                android:background="@drawable/bg_portfolio_placeholder"
                android:visibility="gone" />

            <!-- ============== SERVICES ============== -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp">

                <TextView
                    android:id="@+id/servicesHeader"
                    style="?attr/textAppearanceTitleLarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_services"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/addServiceBtn"
                    style="@style/Widget.Kaushalya.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/add_service"
                    android:visibility="gone"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:icon="@drawable/ic_add" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/servicesRv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingHorizontal="20dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/servicesEmptyTv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/profile_no_services"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp"
                android:textStyle="italic"
                android:gravity="center"
                android:layout_marginHorizontal="20dp"
                android:padding="20dp"
                android:background="@drawable/bg_portfolio_placeholder"
                android:visibility="gone" />

            <!-- ============== REVIEWS ============== -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp">

                <TextView
                    android:id="@+id/reviewsHeader"
                    style="?attr/textAppearanceTitleLarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_reviews"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/addReviewBtn"
                    style="@style/Widget.Kaushalya.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/add_review"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:icon="@drawable/ic_add" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/reviewsRv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingHorizontal="20dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/reviewsEmptyTv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/profile_no_reviews"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp"
                android:textStyle="italic"
                android:gravity="center"
                android:layout_marginHorizontal="20dp"
                android:padding="20dp"
                android:background="@drawable/bg_portfolio_placeholder"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
