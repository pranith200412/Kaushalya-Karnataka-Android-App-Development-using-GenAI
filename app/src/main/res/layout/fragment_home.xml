<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="120dp">

            <!-- ===== Hero header (warm gradient, app name + tagline) ===== -->
            <View
                android:id="@+id/heroBg"
                android:layout_width="0dp"
                android:layout_height="220dp"
                android:background="@drawable/bg_hero_gradient"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <ImageView
                android:id="@+id/logoIv"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_logo"
                android:importantForAccessibility="no"
                android:layout_marginTop="48dp"
                android:layout_marginStart="24dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/appNameTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:layout_marginStart="12dp"
                app:layout_constraintTop_toTopOf="@id/logoIv"
                app:layout_constraintBottom_toBottomOf="@id/logoIv"
                app:layout_constraintStart_toEndOf="@id/logoIv" />

            <TextView
                android:id="@+id/heroTitleTv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/home_greeting"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:lineSpacingExtra="2dp"
                android:layout_marginTop="92dp"
                android:layout_marginHorizontal="24dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/heroSubTv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/home_subgreeting"
                android:textColor="#FFFFFFEE"
                android:textSize="14sp"
                android:layout_marginTop="6dp"
                android:layout_marginHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@id/heroTitleTv"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- ===== Search bar (floating between hero and content) ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/searchCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="180dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="6dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_search"
                        android:padding="10dp"
                        android:importantForAccessibility="no" />

                    <EditText
                        android:id="@+id/searchEt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="@string/search_hint"
                        android:textColor="?attr/colorOnSurface"
                        android:textColorHint="?attr/colorOnSurfaceVariant"
                        android:textSize="15sp"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1"
                        android:autofillHints="" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Category chips ===== -->
            <HorizontalScrollView
                android:id="@+id/chipScroll"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/searchCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/categoryChipGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="20dp"
                    app:singleLine="true"
                    app:singleSelection="true"
                    app:selectionRequired="true" />
            </HorizontalScrollView>

            <!-- ===== Worker list ===== -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/workerRv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:paddingHorizontal="20dp"
                android:clipToPadding="false"
                android:overScrollMode="never"
                app:layout_constraintTop_toBottomOf="@id/chipScroll"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- ===== Empty state ===== -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="48dp"
                android:layout_marginHorizontal="32dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/chipScroll"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_work"
                    android:importantForAccessibility="no" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/empty_workers_title"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/empty_workers_body"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/becomeWorkerFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/onboarding_register"
        android:textColor="?attr/colorOnPrimary"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="100dp"
        android:layout_gravity="bottom|end"
        app:backgroundTint="?attr/colorPrimary"
        app:icon="@drawable/ic_add"
        app:iconTint="?attr/colorOnPrimary" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
