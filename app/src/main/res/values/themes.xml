<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Kaushalya" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <item name="colorPrimaryContainer">@color/brand_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/brand_on_primary_container</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/brand_on_secondary</item>
        <item name="colorSecondaryContainer">@color/brand_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/brand_on_secondary_container</item>

        <!-- Tertiary -->
        <item name="colorTertiary">@color/brand_tertiary</item>
        <item name="colorOnTertiary">@color/brand_on_tertiary</item>
        <item name="colorTertiaryContainer">@color/brand_tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/brand_on_tertiary_container</item>

        <!-- Surface / background -->
        <item name="android:colorBackground">@color/brand_background</item>
        <item name="colorOnBackground">@color/brand_on_background</item>
        <item name="colorSurface">@color/brand_surface</item>
        <item name="colorOnSurface">@color/brand_on_surface</item>
        <item name="colorSurfaceVariant">@color/brand_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/brand_on_surface_variant</item>
        <item name="colorSurfaceContainer">@color/brand_surface_container</item>
        <item name="colorSurfaceContainerHigh">@color/brand_surface_container_high</item>
        <item name="colorOutline">@color/brand_outline</item>
        <item name="colorOutlineVariant">@color/brand_outline_variant</item>

        <!-- Error -->
        <item name="colorError">@color/brand_error</item>
        <item name="colorOnError">@color/brand_on_error</item>
        <item name="colorErrorContainer">@color/brand_error_container</item>
        <item name="colorOnErrorContainer">@color/brand_on_error_container</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/brand_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/brand_surface</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>

        <!-- Default text appearances we tweak for warmth -->
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.Kaushalya.DisplayLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.Kaushalya.Headline</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Kaushalya.Title</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Kaushalya.Body</item>
    </style>

    <style name="Theme.Kaushalya.Splash" parent="Theme.Kaushalya">
        <item name="android:windowBackground">@color/brand_primary</item>
    </style>

    <!-- ======================== Text appearances ======================== -->

    <style name="TextAppearance.Kaushalya.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.Kaushalya.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.Kaushalya.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Kaushalya.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.Kaushalya.OnPrimary" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/colorOnPrimary</item>
    </style>

    <!-- ======================== Component styles ======================== -->

    <style name="Widget.Kaushalya.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">?attr/colorSurfaceContainer</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <style name="Widget.Kaushalya.Card.Service" parent="Widget.Kaushalya.Card">
        <item name="cardBackgroundColor">?attr/colorPrimaryContainer</item>
        <item name="strokeColor">@android:color/transparent</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="Widget.Kaushalya.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Kaushalya.Button.HireMe" parent="Widget.Material3.Button">
        <item name="android:textColor">?attr/colorOnSecondary</item>
        <item name="backgroundTint">?attr/colorSecondary</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">18sp</item>
        <item name="iconTint">?attr/colorOnSecondary</item>
    </style>

    <style name="Widget.Kaushalya.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="strokeColor">?attr/colorPrimary</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Kaushalya.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Kaushalya.TextField" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeColor">?attr/colorPrimary</item>
        <item name="hintTextColor">?attr/colorPrimary</item>
        <item name="android:textColorHint">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="Widget.Kaushalya.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_filter_bg</item>
        <item name="android:textColor">@color/chip_filter_fg</item>
        <item name="chipStrokeColor">?attr/colorOutlineVariant</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="checkedIconTint">?attr/colorOnPrimary</item>
    </style>

    <style name="Widget.Kaushalya.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">?attr/colorSurfaceContainer</item>
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.Kaushalya.BottomNav.ActiveIndicator</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <style name="Widget.Kaushalya.BottomNav.ActiveIndicator"
        parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <!-- Light warm container behind the selected icon. The selected icon itself
             uses ?attr/colorPrimary (set via @color/bottom_nav_item_color), giving
             dark-warm-on-light-warm — a high-contrast on-brand pairing. -->
        <item name="android:color">?attr/colorPrimaryContainer</item>
    </style>

    <style name="ShapeAppearance.Kaushalya.Avatar" parent="ShapeAppearance.Material3.Corner.Full" />

    <style name="ShapeAppearance.Kaushalya.Image" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">16dp</item>
    </style>
</resources>
